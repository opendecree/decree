.nh
.TH "DECREE" "1" "Jan 2026" "OpenDecree" "OpenDecree CLI"

.SH NAME
decree-audit - Query audit logs and usage statistics


.SH SYNOPSIS
\fBdecree audit [flags]\fP


.SH DESCRIPTION
Query the configuration change history and field read usage statistics. Useful for compliance auditing and identifying unused fields.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for audit


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--insecure\fP[=false]
	disable TLS (plaintext); for local development only

.PP
\fB-o\fP, \fB--output\fP="table"
	output format: table, json, yaml

.PP
\fB--role\fP="superadmin"
	actor role (x-role header)

.PP
\fB--server\fP="localhost:9090"
	gRPC server address

.PP
\fB--subject\fP=""
	actor identity (x-subject header)

.PP
\fB--tenant-id\fP=""
	auth tenant ID (x-tenant-id header)

.PP
\fB--token\fP=""
	JWT bearer token (prefer DECREE_TOKEN env var to avoid shell history exposure)

.PP
\fB--token-file\fP=""
	path to a file containing the JWT bearer token (takes precedence over --token)

.PP
\fB--wait\fP[=false]
	wait for the server to be ready before executing the command

.PP
\fB--wait-timeout\fP="60s"
	maximum time to wait for server readiness


.SH SEE ALSO
\fBdecree(1)\fP, \fBdecree-audit-query(1)\fP, \fBdecree-audit-unused(1)\fP, \fBdecree-audit-usage(1)\fP, \fBdecree-audit-verify(1)\fP
